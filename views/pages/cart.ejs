<div id="app">
  <h1 class="font-display text-3xl font-extrabold text-ink mb-6">購物車</h1>

  <div v-if="loading" class="flex justify-center py-12">
    <div class="w-8 h-8 border-4 border-coral border-t-transparent rounded-full animate-spin"></div>
  </div>

  <div v-else-if="items.length === 0" class="text-center py-12">
    <div class="text-4xl mb-3">&#128722;</div>
    <p class="text-text-secondary mb-1">購物車是空的</p>
    <p class="text-text-muted text-sm mb-4">快去挑選喜歡的花束吧！</p>
    <a href="/" class="inline-block bg-coral text-white px-6 py-2 rounded-md text-sm hover:bg-coral-deep transition-colors">去逛逛</a>
  </div>

  <template v-else>
    <!-- Free shipping banner -->
    <div v-if="total < 500" class="bg-marigold/40 rounded-md p-3 mb-6 text-sm text-ink text-center font-medium">
      &#127803; 再買 NT$ {{ (500 - total).toLocaleString() }} 即可享免運費！
    </div>
    <div v-else class="bg-stem/15 rounded-md p-3 mb-6 text-sm text-stem text-center">
      &#10003; 已達免運門檻！
    </div>

    <!-- Cart Items -->
    <div class="bg-white rounded-lg border-2 border-ink overflow-hidden mb-6">
      <div
        v-for="item in items"
        :key="item.id"
        class="flex items-center gap-4 p-4 border-b border-gray-100 last:border-0"
      >
        <img
          :src="item.product.image_url || 'https://images.unsplash.com/photo-1490750967868-88aa4f44baee?w=100'"
          :alt="item.product.name"
          class="w-16 h-16 rounded-md object-cover flex-shrink-0"
        />
        <div class="flex-1 min-w-0">
          <h3 class="font-medium text-ink text-sm truncate">{{ item.product.name }}</h3>
          <p class="text-coral text-sm">NT$ {{ item.product.price.toLocaleString() }}</p>
        </div>

        <!-- Quantity Controls -->
        <div class="flex items-center border-2 border-ink rounded-md overflow-hidden">
          <button
            @click="updateQuantity(item.id, item.quantity - 1)"
            :disabled="item.quantity <= 1"
            class="w-8 h-8 flex items-center justify-center hover:bg-marigold/20 text-ink text-sm disabled:opacity-40"
          >
            -
          </button>
          <span class="w-8 h-8 flex items-center justify-center text-sm border-x-2 border-ink">
            {{ item.quantity }}
          </span>
          <button
            @click="updateQuantity(item.id, item.quantity + 1)"
            :disabled="item.quantity >= item.product.stock"
            class="w-8 h-8 flex items-center justify-center hover:bg-marigold/20 text-ink text-sm disabled:opacity-40 disabled:cursor-not-allowed"
          >
            +
          </button>
        </div>

        <p class="font-hand text-ink font-bold text-lg w-24 text-right">
          NT$ {{ (item.product.price * item.quantity).toLocaleString() }}
        </p>

        <button
          @click="confirmDelete(item.id)"
          class="text-text-muted hover:text-red-500 transition-colors text-sm ml-2"
        >
          &#128465;
        </button>
      </div>
    </div>

    <!-- Summary -->
    <div class="bg-ink rounded-lg p-6">
      <div class="flex justify-between items-center mb-2 text-sm">
        <span class="text-white/70">商品小計</span>
        <span class="text-white">NT$ {{ total.toLocaleString() }}</span>
      </div>
      <div class="flex justify-between items-center mb-4 text-sm">
        <span class="text-white/70">運費</span>
        <span class="text-white">{{ total >= 500 ? '免運' : 'NT$ 150' }}</span>
      </div>
      <div class="border-t border-white/20 pt-4 flex justify-between items-center">
        <span class="font-display font-extrabold text-white">總計</span>
        <span class="font-hand font-bold text-3xl text-marigold">
          NT$ {{ (total + (total >= 500 ? 0 : 150)).toLocaleString() }}
        </span>
      </div>
      <button
        @click="goCheckout"
        class="w-full mt-4 bg-coral text-white py-3 rounded-md text-sm font-medium hover:bg-coral-deep transition-colors"
      >
        前往結帳
      </button>
    </div>
  </template>

  <!-- Confirm Dialog -->
  <div v-if="confirmVisible" class="fixed inset-0 z-50 flex items-center justify-center">
    <div class="absolute inset-0 bg-black/40" @click="confirmVisible = false"></div>
    <div class="relative bg-white rounded-lg border-2 border-ink w-full max-w-sm mx-4 p-6 text-center">
      <h3 class="font-display text-lg font-bold text-ink mb-2">確認移除</h3>
      <p class="text-text-secondary text-sm mb-6">確定要從購物車中移除這個商品嗎？</p>
      <div class="flex gap-3 justify-center">
        <button @click="confirmVisible = false" class="px-4 py-2 text-sm rounded-md border-2 border-ink text-ink hover:bg-marigold/20">取消</button>
        <button @click="handleDelete" class="px-4 py-2 text-sm rounded-md bg-red-500 text-white hover:bg-red-600">確認移除</button>
      </div>
    </div>
  </div>
</div>
