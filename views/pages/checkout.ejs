<div id="app">
  <h1 class="font-display text-3xl font-extrabold text-ink mb-6">結帳資訊</h1>

  <div v-if="loading" class="flex justify-center py-12">
    <div class="w-8 h-8 border-4 border-coral border-t-transparent rounded-full animate-spin"></div>
  </div>

  <div v-else class="flex flex-col lg:flex-row gap-8">
    <!-- Left: Form -->
    <div class="lg:w-3/5">
      <div class="bg-white rounded-lg border-2 border-ink p-6">
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-ink mb-1">收件人姓名</label>
            <input
              v-model="form.recipientName"
              type="text"
              placeholder="請輸入收件人姓名"
              class="w-full border border-text-muted rounded-md px-3 py-2 text-sm focus:outline-none focus:border-coral transition-colors"
              :class="{ 'border-red-400': errors.recipientName }"
            />
            <p v-if="errors.recipientName" class="text-red-500 text-xs mt-1">{{ errors.recipientName }}</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-ink mb-1">Email</label>
            <input
              v-model="form.recipientEmail"
              type="email"
              placeholder="請輸入 Email"
              class="w-full border border-text-muted rounded-md px-3 py-2 text-sm focus:outline-none focus:border-coral transition-colors"
              :class="{ 'border-red-400': errors.recipientEmail }"
            />
            <p v-if="errors.recipientEmail" class="text-red-500 text-xs mt-1">{{ errors.recipientEmail }}</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-ink mb-1">收件地址</label>
            <input
              v-model="form.recipientAddress"
              type="text"
              placeholder="請輸入收件地址"
              class="w-full border border-text-muted rounded-md px-3 py-2 text-sm focus:outline-none focus:border-coral transition-colors"
              :class="{ 'border-red-400': errors.recipientAddress }"
            />
            <p v-if="errors.recipientAddress" class="text-red-500 text-xs mt-1">{{ errors.recipientAddress }}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Summary -->
    <div class="lg:w-2/5">
      <div class="bg-ink rounded-lg p-6 sticky top-24">
        <h2 class="font-display font-extrabold text-white mb-4">訂單摘要</h2>
        <div class="space-y-3 mb-4">
          <div v-for="item in cartItems" :key="item.id" class="flex justify-between text-sm">
            <span class="text-white/70">{{ item.product.name }} x {{ item.quantity }}</span>
            <span class="text-white">NT$ {{ (item.product.price * item.quantity).toLocaleString() }}</span>
          </div>
        </div>
        <div class="border-t border-white/20 pt-3 space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-white/70">商品小計</span>
            <span class="text-white">NT$ {{ cartTotal.toLocaleString() }}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-white/70">運費</span>
            <span class="text-white">{{ cartTotal >= 500 ? '免運' : 'NT$ 150' }}</span>
          </div>
        </div>
        <div class="border-t border-white/20 pt-3 mt-3 flex justify-between items-center">
          <span class="font-display font-extrabold text-white">總計</span>
          <span class="font-hand font-bold text-3xl text-marigold">
            NT$ {{ (cartTotal + (cartTotal >= 500 ? 0 : 150)).toLocaleString() }}
          </span>
        </div>
        <button
          @click="submitOrder"
          :disabled="submitting"
          class="w-full mt-4 bg-coral text-white py-3 rounded-md text-sm font-medium hover:bg-coral-deep transition-colors disabled:opacity-50"
        >
          {{ submitting ? '處理中...' : '確認送出訂單' }}
        </button>
      </div>
    </div>
  </div>
</div>
