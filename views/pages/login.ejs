<div id="app">
  <div class="min-h-[60vh] flex items-center justify-center">
    <div class="bg-white rounded-lg border-2 border-ink w-full max-w-md overflow-hidden">
      <!-- Tabs -->
      <div class="flex">
        <button
          @click="activeTab = 'login'; errors = {}"
          class="flex-1 py-4 text-sm font-display font-bold transition-colors"
          :class="activeTab === 'login' ? 'bg-ink text-white' : 'bg-white text-text-muted hover:bg-marigold/10'"
        >
          登入
        </button>
        <button
          @click="activeTab = 'register'; errors = {}"
          class="flex-1 py-4 text-sm font-display font-bold transition-colors"
          :class="activeTab === 'register' ? 'bg-ink text-white' : 'bg-white text-text-muted hover:bg-marigold/10'"
        >
          註冊
        </button>
      </div>

      <div class="p-8">
        <p class="font-display text-coral text-xs font-bold tracking-widest mb-5">▸ 歡迎回到花漾生活</p>

        <!-- Login Form -->
        <form v-if="activeTab === 'login'" @submit.prevent="handleLogin" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-ink mb-1">電子郵件</label>
            <input
              v-model="loginForm.email"
              type="email"
              placeholder="you@example.com"
              class="w-full border border-text-muted rounded-md px-3 py-2 text-sm focus:outline-none focus:border-coral"
              :class="{ 'border-red-400': errors.email }"
            />
            <p v-if="errors.email" class="text-red-500 text-xs mt-1">{{ errors.email }}</p>
          </div>

          <div>
            <label class="block text-sm font-medium text-ink mb-1">密碼</label>
            <input
              v-model="loginForm.password"
              type="password"
              placeholder="請輸入密碼"
              class="w-full border border-text-muted rounded-md px-3 py-2 text-sm focus:outline-none focus:border-coral"
              :class="{ 'border-red-400': errors.password }"
            />
            <p v-if="errors.password" class="text-red-500 text-xs mt-1">{{ errors.password }}</p>
          </div>

          <button
            type="submit"
            :disabled="submitting"
            class="w-full bg-coral text-white py-3 rounded-md text-sm font-medium hover:bg-coral-deep transition-colors disabled:opacity-50"
          >
            {{ submitting ? '登入中...' : '登入' }}
          </button>
        </form>

        <!-- Register Form -->
        <form v-else @submit.prevent="handleRegister" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-ink mb-1">姓名</label>
            <input
              v-model="registerForm.name"
              type="text"
              placeholder="請輸入姓名"
              class="w-full border border-text-muted rounded-md px-3 py-2 text-sm focus:outline-none focus:border-coral"
              :class="{ 'border-red-400': errors.name }"
            />
            <p v-if="errors.name" class="text-red-500 text-xs mt-1">{{ errors.name }}</p>
          </div>

          <div>
            <label class="block text-sm font-medium text-ink mb-1">電子郵件</label>
            <input
              v-model="registerForm.email"
              type="email"
              placeholder="you@example.com"
              class="w-full border border-text-muted rounded-md px-3 py-2 text-sm focus:outline-none focus:border-coral"
              :class="{ 'border-red-400': errors.email }"
            />
            <p v-if="errors.email" class="text-red-500 text-xs mt-1">{{ errors.email }}</p>
          </div>

          <div>
            <label class="block text-sm font-medium text-ink mb-1">密碼</label>
            <input
              v-model="registerForm.password"
              type="password"
              placeholder="至少 6 個字元"
              class="w-full border border-text-muted rounded-md px-3 py-2 text-sm focus:outline-none focus:border-coral"
              :class="{ 'border-red-400': errors.password }"
            />
            <p v-if="errors.password" class="text-red-500 text-xs mt-1">{{ errors.password }}</p>
          </div>

          <button
            type="submit"
            :disabled="submitting"
            class="w-full bg-coral text-white py-3 rounded-md text-sm font-medium hover:bg-coral-deep transition-colors disabled:opacity-50"
          >
            {{ submitting ? '註冊中...' : '註冊' }}
          </button>
        </form>
      </div>
    </div>
  </div>
</div>
