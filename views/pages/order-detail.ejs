<div id="app" data-order-id="<%= orderId %>" data-payment-result="<%= paymentResult %>">
  <div class="flex items-center justify-between mb-6">
    <h1 class="font-display text-3xl font-extrabold text-ink">訂單詳情</h1>
  </div>

  <div v-if="loading" class="flex justify-center py-12">
    <div class="w-8 h-8 border-4 border-coral border-t-transparent rounded-full animate-spin"></div>
  </div>

  <template v-else-if="order">
    <!-- Payment Result Alert -->
    <div
      v-if="paymentResult && paymentMessages[paymentResult]"
      class="rounded-md p-4 mb-6 text-sm"
      :class="paymentMessages[paymentResult].cls"
    >
      {{ paymentMessages[paymentResult].text }}
    </div>

    <!-- Order Info -->
    <div class="flex items-center justify-between mb-6">
      <h2 class="font-display text-lg font-bold text-ink">{{ order.order_no }}</h2>
      <span
        class="text-xs px-3 py-1 rounded-full font-medium"
        :class="statusMap[order.status]?.cls || 'bg-gray-100 text-gray-600'"
      >
        {{ statusMap[order.status]?.label || order.status }}
      </span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <!-- Recipient Info -->
      <div class="bg-white rounded-lg border-2 border-ink p-5">
        <p class="font-display text-coral text-xs font-bold tracking-widest mb-2">▸ 收件資訊</p>
        <div class="text-sm space-y-1 text-text-secondary">
          <p class="text-ink">{{ order.recipient_name }}</p>
          <p>{{ order.recipient_email }}</p>
          <p>{{ order.recipient_address }}</p>
        </div>
      </div>

      <!-- Order Date Info -->
      <div class="bg-white rounded-lg border-2 border-ink p-5">
        <p class="font-display text-coral text-xs font-bold tracking-widest mb-2">▸ 訂單資訊</p>
        <div class="text-sm space-y-1 text-text-secondary">
          <p>訂購日期：{{ new Date(order.created_at).toLocaleDateString('zh-TW') }}</p>
        </div>
      </div>
    </div>

    <!-- Order Items -->
    <div class="bg-white rounded-lg border-2 border-ink overflow-hidden mb-6">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-ink text-white">
            <th class="text-left py-3 px-5 font-medium">商品名稱</th>
            <th class="text-right py-3 px-5 font-medium">單價</th>
            <th class="text-right py-3 px-5 font-medium">數量</th>
            <th class="text-right py-3 px-5 font-medium">小計</th>
          </tr>
        </thead>
        <tbody>
          <tr v-for="item in order.items" :key="item.id" class="border-b border-gray-100">
            <td class="py-3 px-5 text-ink">{{ item.product_name }}</td>
            <td class="py-3 px-5 text-right text-text-secondary">NT$ {{ item.product_price.toLocaleString() }}</td>
            <td class="py-3 px-5 text-right text-text-secondary">{{ item.quantity }}</td>
            <td class="py-3 px-5 text-right font-hand font-bold text-coral text-lg">NT$ {{ (item.product_price * item.quantity).toLocaleString() }}</td>
          </tr>
        </tbody>
        <tfoot>
          <tr class="bg-blush">
            <td colspan="3" class="py-3 px-5 text-right text-text-secondary">訂單總計：</td>
            <td class="py-3 px-5 text-right font-display font-extrabold text-ink text-lg">NT$ {{ order.total_amount.toLocaleString() }}</td>
          </tr>
        </tfoot>
      </table>
    </div>

    <!-- Payment Actions -->
    <div v-if="order.status === 'pending'" class="flex gap-4">
      <button
        @click="checkPayment"
        :disabled="paying"
        class="bg-stem text-white px-8 py-3 rounded-md text-sm font-medium hover:bg-stem/90 transition-colors disabled:opacity-50"
      >
        {{ paying ? '查詢中...' : '查詢付款狀態' }}
      </button>
      <a
        :href="'/ecpay/payment/' + order.id"
        class="inline-block bg-coral text-white px-8 py-3 rounded-md text-sm font-medium hover:bg-coral-deep transition-colors text-center"
      >
        前往付款
      </a>
    </div>
  </template>
</div>
