<div id="app">
  <h1 class="font-display text-3xl font-extrabold text-ink mb-6">我的訂單</h1>

  <div v-if="loading" class="flex justify-center py-12">
    <div class="w-8 h-8 border-4 border-coral border-t-transparent rounded-full animate-spin"></div>
  </div>

  <div v-else-if="orders.length === 0" class="text-center py-12">
    <div class="text-4xl mb-3">&#128230;</div>
    <p class="text-text-secondary mb-1">尚無訂單</p>
    <p class="text-text-muted text-sm mb-4">快去選購喜歡的花束吧！</p>
    <a href="/" class="inline-block bg-coral text-white px-6 py-2 rounded-md text-sm hover:bg-coral-deep transition-colors">去逛逛</a>
  </div>

  <div v-else class="space-y-4">
    <a
      v-for="order in orders"
      :key="order.id"
      :href="'/orders/' + order.id"
      class="block bg-white rounded-lg border-2 border-ink p-5 hover:shadow-md transition-shadow"
    >
      <div class="flex items-center justify-between">
        <div>
          <p class="font-display text-sm font-bold text-ink">{{ order.order_no }}</p>
          <p class="text-xs text-text-muted mt-1">{{ new Date(order.created_at).toLocaleDateString('zh-TW') }}</p>
        </div>
        <div class="flex items-center gap-3">
          <span
            class="text-xs px-3 py-1 rounded-full font-medium"
            :class="statusMap[order.status]?.cls || 'bg-gray-100 text-gray-600'"
          >
            {{ statusMap[order.status]?.label || order.status }}
          </span>
          <span class="font-hand font-bold text-xl text-coral">NT$ {{ order.total_amount.toLocaleString() }}</span>
          <span class="text-text-muted">&#8594;</span>
        </div>
      </div>
    </a>
  </div>
</div>
